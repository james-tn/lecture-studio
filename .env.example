# Copy to `.env` and fill in your Azure resource names. `.env` is git-ignored.
# The app authenticates keylessly via the logged-in `az` CLI (no API keys here).

# Azure OpenAI v1 endpoint (chat + Responses API + OpenAI TTS):
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/openai/v1

# Azure AI Services / Foundry host (image generation: FLUX.2-pro, gpt-image-2):
AZURE_AI_SERVICES_ENDPOINT=https://YOUR-RESOURCE.services.ai.azure.com

# Azure Speech (default narration backend, keyless AAD):
AZURE_SPEECH_REGION=YOUR-REGION
AZURE_SPEECH_RESOURCE_GROUP=YOUR-RESOURCE-GROUP
AZURE_SPEECH_ACCOUNT=YOUR-RESOURCE

# Optional overrides:
# AZURE_CHAT_MODEL=gpt-5.4
# AZURE_IMAGE_BACKEND=flux            # flux | gpt-image
# AZURE_TTS_MODEL=gpt-4o-mini-tts
